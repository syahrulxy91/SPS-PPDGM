rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Catch-all Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isMaintainer() {
      return isSignedIn() && 
        request.auth.token.email != null && 
        request.auth.token.email == "syahrulxy91@gmail.com";
    }

    // Centralized Google Drive & System Settings Configuration
    match /systemSettings/{configId} {
      // Allow authenticated user with @moe.gov.my or maintainer to read configuration settings
      allow read: if isSignedIn() && (
        request.auth.token.email == "syahrulxy91@gmail.com" || 
        request.auth.token.email.endsWith("@moe.gov.my")
      );
      // Only the static system maintainer can write to systemSettings
      allow write: if isMaintainer();
    }

    // Sektor Pengurusan Sekolah Organizational Structure
    match /organisasi/{nodeId} {
      allow read: if isSignedIn() && (
        request.auth.token.email == "syahrulxy91@gmail.com" || 
        request.auth.token.email.endsWith("@moe.gov.my")
      );
      allow write: if isMaintainer();
    }
  }
}
