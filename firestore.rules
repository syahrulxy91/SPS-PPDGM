rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Default-deny Catch-all ──────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Helper Functions ────────────────────────────────────
    function isSuperAdminUser() {
      return request.auth != null && (
        request.auth.token.email.toLowerCase() == "syahrulxy91@gmail.com" ||
        (exists(/databases/$(database)/documents/roleAssignments/$(request.auth.token.email.toLowerCase())) &&
         get(/databases/$(database)/documents/roleAssignments/$(request.auth.token.email.toLowerCase())).data.role == "SUPER ADMIN")
      );
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/roleAssignments/$(request.auth.token.email.toLowerCase())).data.role;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSeniorRole() {
      return isAuthenticated() && getUserRole() in ["SUPER ADMIN", "ADMIN SPS", "KETUA UNIT"];
    }

    // ── System Settings ─────────────────────────────────────
    match /systemSettings/{configId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdminUser();
    }

    // ── Organisasi ──────────────────────────────────────────
    match /organisasi/{nodeId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdminUser();
    }

    // ── Role Assignments ────────────────────────────────────
    match /roleAssignments/{email} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdminUser();
    }

    // ── Reports / Dokumen ───────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdminUser() || isSeniorRole();
    }

    // ── Audit Logs ──────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if isSuperAdminUser();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ── Drive Folder Cache ──────────────────────────────────
    // Ditulis oleh Cloud Functions (Admin SDK bypass rules)
    // Dibaca oleh Super Admin sahaja untuk debugging
    match /driveFolderCache/{unitName} {
      allow read: if isSuperAdminUser();
      allow write: if false;
    }

  }
}